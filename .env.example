# Copy this file to .env in the project root.

# ── Core ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/salex
PORT=4000

# Auth
JWT_SECRET=change-this-to-a-random-64-char-string

# Worker
# Ayrıca worker prosesi işlədəndə false et
RUN_WORKER_IN_SERVER=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=botfather_dan_al
TELEGRAM_WEBHOOK_URL=https://yourdomain.com
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourSALexBot

# SMS (Faza 1 üçün — provayderə görə dəyişir)
# SMS_API_KEY=
# SMS_SENDER=SALex


# Public origin of this API (scheme + host + port, no path). Used by the publish worker to
# download listing images when URLs are stored as `/uploads/...`. Default: http://127.0.0.1:$PORT
# Set in production if the worker reaches the API via a different host than localhost.
# PUBLIC_API_ORIGIN=https://api.example.com

# ── Frontend ──
# Backend URL for Next.js API proxy (rewrites). Default: http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── External services ──
GEMINI_API_KEY=MY_GEMINI_API_KEY
APP_URL=http://localhost:3000

# Optional Selenium recovery settings for Tap.az connector.
# If CHROME_BIN is not set, Selenium will try to use the system Chrome/Chromium.
TAPAZ_SELENIUM_HEADLESS=true
TAPAZ_SELENIUM_TIMEOUT_MS=15000

# Tap.az login credentials.
# Phone number used to log in to Tap.az (with country code, e.g. +994501234567).
TAPAZ_LOGIN_PHONE=
# Static OTP code for testing. If set, file-based OTP polling is skipped.
TAPAZ_OTP_CODE=
# File path where the worker writes "WAITING" and reads the OTP from.
# Default: .tapaz-otp in the project root.
TAPAZ_OTP_FILE=
# How long (ms) to wait for OTP to appear in the file. Default: 120000 (2 minutes).
TAPAZ_OTP_TIMEOUT_MS=120000

# Optional Selenium recovery settings for Lalafo connector.
LALAFO_SELENIUM_HEADLESS=true
LALAFO_SELENIUM_TIMEOUT_MS=15000

# Lalafo login credentials.
LALAFO_LOGIN_PHONE=
LALAFO_OTP_CODE=
LALAFO_OTP_FILE=
LALAFO_OTP_TIMEOUT_MS=120000

# Optional Selenium settings for Alan.az connector.
ALANAZ_SELENIUM_HEADLESS=true
ALANAZ_SELENIUM_TIMEOUT_MS=15000

# Alan.az login credentials.
ALANAZ_LOGIN_PHONE=
ALANAZ_OTP_CODE=
ALANAZ_OTP_FILE=
ALANAZ_OTP_TIMEOUT_MS=120000

# Optional Selenium settings for Laylo.az connector.
LAYLO_SELENIUM_HEADLESS=true
LAYLO_SELENIUM_TIMEOUT_MS=15000

# Laylo.az login credentials.
LAYLO_LOGIN_PHONE=
LAYLO_OTP_CODE=
LAYLO_OTP_FILE=
LAYLO_OTP_TIMEOUT_MS=120000

# Optional Selenium settings for Birja.com connector.
BIRJACOM_SELENIUM_HEADLESS=true
BIRJACOM_SELENIUM_TIMEOUT_MS=15000

# Birja.com login credentials.
BIRJACOM_LOGIN_PHONE=
BIRJACOM_OTP_CODE=
BIRJACOM_OTP_FILE=
BIRJACOM_OTP_TIMEOUT_MS=120000

# Shared Chrome binary path for all Selenium connectors.
CHROME_BIN=

# Automatic pending-link recovery scheduling.
# Cron expression for how often recovery runs. Default: every 10 minutes.
RECOVERY_SCHEDULE_CRON=*/10 * * * *
# Maximum recovery attempts per platform result. Default: 5.
MAX_RECOVERY_RETRIES=5
